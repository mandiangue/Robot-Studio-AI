      st.pages[pi].cases.splice(ci, 1);
      syncStoreToPending(cid); rebuildCard(cid);
    } else if (action === 'del-page' && pi >= 0) {
      st.pages.splice(pi, 1);
      syncStoreToPending(cid); rebuildCard(cid);
    } else if (action === 'add-case' && pi >= 0) {
