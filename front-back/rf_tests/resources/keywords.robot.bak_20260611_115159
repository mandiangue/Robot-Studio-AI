*** Settings ***
Library      Browser
Library      Collections
Resource     variables.robot
Resource     pages/login_page.robot

*** Keywords ***
Open Browser Session
    [Arguments]    ${url}=${BASE_URL}    ${browser}=${BROWSER}
    New Browser    ${browser}    headless=${HEADLESS}
    New Context    acceptDownloads=True
    New Page       ${url}

Open Browser No Popup
    [Arguments]    ${url}    ${browser}=chromium
    Open Browser Session    ${url}    ${browser}

Close Browser
    Close Browser    ALL

Login With Credentials
    [Arguments]    ${username}    ${password}
    Fill Username Field    ${username}
    Fill Password Field    ${password}
    Click Login Button

Verify Successful Login
    Wait For Url Contains    /secure
    Verify Flash Message Contains    ${SUCCESS_MESSAGE}
    Verify Logout Button Visible

Verify Invalid Password Error
    Verify Flash Message Contains    ${INVALID_PASSWORD_MSG}
    Verify Still On Login Page

Verify Invalid Username Error
    Verify Flash Message Contains    ${INVALID_USERNAME_MSG}
    Verify Still On Login Page

Verify Logout Success
    Wait For Url Contains    /login
    Verify Flash Message Contains    ${LOGOUT_MESSAGE}

Wait For Url Contains
    [Arguments]    ${fragment}
    Wait For Condition    url    contains    ${fragment}    timeout=10s
