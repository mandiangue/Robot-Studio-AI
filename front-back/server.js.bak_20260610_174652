app.post('/api/install-library', (req, res) => {
  const { library } = req.body;
  const pkg = LIBRARY_PACKAGES[library];
  if (!pkg) return res.status(400).json({ error: 'Librairie inconnue: ' + library });

  // Built-in library — no install needed
  if (pkg.builtin) {
    res.setHeader('Content-Type', 'text/event-stream');
    res.flushHeaders();
    res.write('data: ' + JSON.stringify({ msg: '✅ ' + library + ' est une librairie intégrée à Robot Framework — déjà disponible !' }) + '\n\n');
    res.write('data: ' + JSON.stringify({ done: true, success: true }) + '\n\n');
    return res.end();
  }

  console.log('Installing:', pkg.pip);
  res.setHeader('Content-Type', 'text/event-stream');
  res.setHeader('Cache-Control', 'no-cache');
  res.flushHeaders();

  const send = (msg) => res.write('data: ' + JSON.stringify({ msg }) + '\n\n');

  send('📦 Installation de ' + pkg.pip + '...');

  const proc = exec('pip install ' + pkg.pip + ' --break-system-packages --quiet', (err, stdout, stderr) => {
    if (err) {
      send('❌ Erreur: ' + (stderr || err.message));
      res.write('data: ' + JSON.stringify({ done: true, success: false }) + '\n\n');
      return res.end();
    }
    send('✅ ' + pkg.pip + ' installé !');

    if (pkg.post) {
      send('⚙️ Configuration: ' + pkg.post + '...');
      exec(pkg.post, (err2, stdout2, stderr2) => {
        if (err2) send('⚠️ Post-install: ' + (stderr2 || err2.message));
        else send('✅ Configuration terminée !');
        res.write('data: ' + JSON.stringify({ done: true, success: !err2 }) + '\n\n');
        res.end();
      });
    } else {
      res.write('data: ' + JSON.stringify({ done: true, success: true }) + '\n\n');
      res.end();
    }
  });
});


