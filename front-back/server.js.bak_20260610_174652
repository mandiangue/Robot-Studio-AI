            }
            content = content.replace(m[0], 'Resource    ' + isolatedPath.replace(/\\/g, '/'));
            changed = true;
          }
        }
        if (changed) fs.writeFileSync(fp, content, 'utf8');
      });
    };
    fixPathsInDir(runBaseDir);
  }

  // If POM tests file doesn't exist on disk, check if tests/ folder has any .robot file
  if (isPomTest && !fs.existsSync(robotFile)) {
