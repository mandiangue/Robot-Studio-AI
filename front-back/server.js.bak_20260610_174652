// ── Final cleanup of robot files — remove duplicates and fix keywords ─────────
function finalCleanupRobotFile(filePath) {
  if (!fs.existsSync(filePath)) return;
  try {
    let code = fs.readFileSync(filePath, 'utf8');
    const isBrowser  = code.includes('Library    Browser') && !code.includes('SeleniumLibrary');
    const isResource = code.includes('*** Keywords ***') && !code.includes('*** Test Cases ***');

    // Remove Settings directives from resource files (not allowed)
    if (isResource) {
      ['Test Teardown', 'Suite Setup', 'Suite Teardown', 'Test Setup',
       'Suite Setup    Register', 'Test Teardown    Run Keywords'].forEach(key => {
        const re = new RegExp('^' + key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '[^\n]*\n', 'gm');
        code = code.replace(re, '');
      });
    } else {
      // Remplacer Test Teardown Close Browser par Take Screenshot
      code = code.replace(/^(Test Teardown\s+)(Close Browser|Close Application)\s*$/gm, 'Test Teardown    Take Screenshot');
      // For Browser lib: remove Test Teardown Take Screenshot entirely (page may be closed)
      if (isBrowser) {
        code = code.replace(/^Test Teardown\s+Take Screenshot\s*\n/gm, '');
        code = code.replace(/^Test Teardown\s+Run Keywords.*Screenshot.*\n/gm, '');
      }
      // Remove duplicate Test Teardown / Suite Setup — keep last
      ['Test Teardown', 'Suite Setup', 'Suite Teardown', 'Test Setup'].forEach(key => {
        const re = new RegExp('^' + key + '[^\n]*\n', 'gm');
        const matches = code.match(re) || [];
        if (matches.length > 1) {
          matches.slice(0, -1).forEach(m => { code = code.replace(m, ''); });
        }
      });
    }

    // Fix bare #id selectors in variable values → add css= prefix
    code = code.replace(/^(\$\{\w+\})\s+(#[\w-]+)$/gm, '$1    css=$2');

    // Final keyword fix for Browser lib
    if (isBrowser) {
      code = code.replace(/Capture Page Screenshot/g, 'Take Screenshot');
    }

    fs.writeFileSync(filePath, code, 'utf8');
  } catch(e) { console.error('  Cleanup error:', e.message); }
}

// ── Remove duplicate keyword definitions across files ─────────────────────────
function deduplicateKeywords(testsDir) {
  const keywordMap = {}; // keyword name → first file that defines it
  const robotDirs = [
    path.join(testsDir, 'resources'),
    path.join(testsDir, 'resources', 'pages'),
    path.join(testsDir, 'tests'),
  ];

  // First pass: collect all keyword definitions
  robotDirs.forEach(dir => {
    if (!fs.existsSync(dir)) return;
    fs.readdirSync(dir).filter(f => f.endsWith('.robot')).forEach(file => {
      const fp = path.join(dir, file);
      const content = fs.readFileSync(fp, 'utf8');
      const kwMatches = [...content.matchAll(/^([A-Za-zÀ-ÿ][^\n]+)\n(?:[ \t]+[^\n]+\n)+/gm)];
      kwMatches.forEach(m => {
        const name = m[1].trim();
        if (!name.startsWith('#') && !name.startsWith('*') && !name.startsWith('$') && !name.startsWith('[')) {
          if (!keywordMap[name]) keywordMap[name] = fp;
        }
      });
    });
  });

  // Second pass: remove duplicate keyword blocks (keep first occurrence)
  const seen = {};
  robotDirs.forEach(dir => {
    if (!fs.existsSync(dir)) return;
    fs.readdirSync(dir).filter(f => f.endsWith('.robot')).forEach(file => {
      const fp = path.join(dir, file);
      let content = fs.readFileSync(fp, 'utf8');
      let changed = false;
      let inKw = false;
      let kwName = '';
      const lines = content.split('\n');
      const result = [];

      for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const t = line.trim();
        if (t.startsWith('*** Keywords')) { inKw = true; result.push(line); continue; }
        if (t.startsWith('***') && !t.startsWith('*** Keywords')) { inKw = false; result.push(line); continue; }
        if (inKw && /^[A-Za-zÀ-ÿ]/.test(line) && !t.startsWith('#')) {
          kwName = t;
          if (seen[kwName] && seen[kwName] !== fp) {
            // Skip this keyword block
            while (i + 1 < lines.length && /^[ \t]/.test(lines[i + 1])) i++;
            changed = true;
            continue;
          }
          seen[kwName] = fp;
        }
        result.push(line);
      }

      if (changed) {
        fs.writeFileSync(fp, result.join('\n'), 'utf8');
        console.log('  Dedup: removed duplicate keywords in', file);
      }
    });
  });
}


// ── Clean Robot Framework code before writing to disk ────────────────────────
function cleanRobotCodeServer(code) {
  if (!code) return '';

  // 0. Fix keywords inexistants
  code = code.replace(/Location Should Not Be/g, 'Location Should Be');
  code = code.replace(/Page Should Not Contain Element/g, 'Page Should Not Contain');
  code = code.replace(/Element Should Not Be Visible/g, 'Element Should Not Be Visible');

  // 1. Fix missing *** Settings *** header
  const firstLine = code.split('\n')[0]?.trim();
  const startsWithDirective = /^(Documentation|Library|Resource|Suite Setup|Suite Teardown)[ \t]+/.test(firstLine);
  if (startsWithDirective && !code.includes('*** Settings')) {
    code = '*** Settings ***\n' + code;
  }

  // 2. Remove duplicate *** Settings *** sections — keep only first
  let settingsCount = 0;
  let skipMode = false;
  const lines = code.split('\n');
  const result = [];
  for (const line of lines) {
    const t = line.trim();
    if (/^\*{3}\s*Settings\s*\*{3}/.test(t)) {
      settingsCount++;
      if (settingsCount > 1) { skipMode = true; continue; }
      skipMode = false;
      result.push(line);
      continue;
    }
    if (/^\*{3}/.test(t) && !/^\*{3}\s*Settings/.test(t)) skipMode = false;
    if (skipMode) continue;
    result.push(line);
  }
  code = result.join('\n');

  // 3. Remove leaked Settings directives AND fake TC_XXX Settings test cases
  const lines2 = code.split('\n');
  let inTests = false;
  let skipFakeTC = false;
  const cleaned = [];

  for (let i = 0; i < lines2.length; i++) {
    const line = lines2[i];
    const t = line.trim();

    if (!t) { if (!skipFakeTC) cleaned.push(line); continue; }
    if (/^\*{3}\s*Test Cases/.test(t)) { inTests = true; skipFakeTC = false; cleaned.push(line); continue; }
    if (/^\*{3}/.test(t))               { inTests = false; skipFakeTC = false; cleaned.push(line); continue; }

    if (inTests) {
      // Detect fake TC: "TC_XXX Documentation ...", "TC_XXX Library ...", "TC_XXX Resource ..."
      const isFakeTC = /^TC_\d+\s+(Documentation|Library|Resource|Suite Setup|Suite Teardown|Variables)\s+/.test(t)
        && !/^\s/.test(line);

      // Also detect raw Settings leaked (no TC_ prefix)
      const isLeakedSetting = /^(Documentation|Library|Resource|Suite Setup|Suite Teardown|Test Setup|Test Teardown|Metadata|Variables)[ \t]+/.test(t)
        && !/^[ \t]/.test(line);

      if (isFakeTC) {
        skipFakeTC = true; // skip this line and its indented body
        continue;
      }
      if (isLeakedSetting) continue;

      // If we hit a real TC (TC_XXX with a real name or BDD step), stop skipping
      if (skipFakeTC && /^[A-Za-zÀ-ÿ0-9_]/.test(line) && !/^\s/.test(line)) {
        skipFakeTC = false;
      }
      if (skipFakeTC) continue; // skip indented body of fake TC
    }

    cleaned.push(line);
  }
  return cleaned.join('\n');
}


// ── Merge duplicate RF sections (Settings, Keywords, Test Cases) ──────────────
function mergeRobotSections(code) {
  const sectionRe = /^(\*{3}[^\n]+\*{3}[^\n]*)$/gm;
  const lines = code.split('\n');
  const sections = {};
  let currentSection = null;

  // Parse all sections
  for (const line of lines) {
    if (/^\*{3}/.test(line.trim())) {
      const name = line.trim().replace(/\*/g,'').trim().split(' ')[0];
      if (!sections[name]) sections[name] = { header: line, lines: [] };
      else sections[name].lines.push(''); // separator
      currentSection = name;
    } else if (currentSection) {
      sections[currentSection].lines.push(line);
    }
  }

  // Rebuild in order: Settings, Variables, Keywords (from pages), Keywords, Test Cases
  const order = ['Settings', 'Variables', 'Keywords', 'Test', 'Tasks'];
  let result = '';
  const added = new Set();

  for (const key of Object.keys(sections)) {
    const sec = sections[key];
    result += sec.header + '\n' + sec.lines.join('\n') + '\n\n';
  }

  return result;
}

function crossCheckKeywords(testsDir) {
  const testsFile   = path.join(testsDir, 'tests.robot');
  const kwFile      = path.join(path.dirname(testsDir), 'resources', 'keywords.robot');
  
  if (!fs.existsSync(testsFile) || !fs.existsSync(kwFile)) return;

  const kwContent   = fs.readFileSync(kwFile, 'utf8');
  const testContent = fs.readFileSync(testsFile, 'utf8');

  // Extract defined keyword names from keywords.robot AND pages/*.robot
  const definedKws = [];
  let inKeywordsSection = false;

  const extractKws = (content) => {
    inKeywordsSection = false;
    content.split('\n').forEach(line => {
      if (line.startsWith('*** Keywords')) { inKeywordsSection = true; return; }
      if (line.startsWith('***')) { inKeywordsSection = false; return; }
      if (inKeywordsSection && line && !/^\s/.test(line) && !line.startsWith('#') && line.trim()) {
        definedKws.push(line.trim());
      }
    });
  };

  extractKws(kwContent);

  // Also check pages/*.robot
  const pagesDir = path.join(path.dirname(testsDir), 'resources', 'pages');
  if (fs.existsSync(pagesDir)) {
    fs.readdirSync(pagesDir).filter(f => f.endsWith('.robot')).forEach(f => {
      try { extractKws(fs.readFileSync(path.join(pagesDir, f), 'utf8')); } catch(e) {}
    });
  }

  if (definedKws.length === 0) return;

  // For each BDD step in tests.robot, find the best matching keyword
  let fixed = testContent;
  const bddPrefixes = ['Given ', 'When ', 'And ', 'Then ', 'But '];

  let inTestCases = false;
  testContent.split('\n').forEach(line => {
    const trimmed = line.trim();
    if (trimmed.startsWith('*** Test Cases')) { inTestCases = true; return; }
    if (trimmed.startsWith('***')) { inTestCases = false; return; }
    if (!inTestCases || !trimmed) return;
    if (!/^\s+/.test(line)) return;

    const prefix = bddPrefixes.find(p => trimmed.startsWith(p));
    if (!prefix) return;

    const stepName = trimmed.slice(prefix.length).trim();

    // 1. Check if keyword exists with NO prefix
    const noPrefixMatch = definedKws.find(kw => kw.toLowerCase() === stepName.toLowerCase());
    if (noPrefixMatch) return; // RF will strip prefix automatically

    // 2. Check if keyword exists WITH a different BDD prefix
    // e.g. test calls "And X" but keyword is "When X" — fix the prefix
    const withPrefixMatch = definedKws.find(kw => {
      const kwNoPrefix = bddPrefixes.reduce((s, p) => s.startsWith(p) ? s.slice(p.length).trim() : s, kw);
      return kwNoPrefix.toLowerCase() === stepName.toLowerCase();
    });
    if (withPrefixMatch) {
      // Replace "And X" with the correct keyword name as defined
      const oldStep = line;
      const indent  = line.match(/^(\s+)/)?.[1] || '    ';
      const newStep = indent + withPrefixMatch;
      fixed = fixed.split('\n').map(l => l === oldStep ? newStep : l).join('\n');
      console.log('  Cross-check prefix fix:', trimmed, '→', withPrefixMatch);
      return;
    }

    // Check if this keyword exists (exact match or BDD prefix variant)
    const exactMatch = definedKws.find(kw =>
      kw.toLowerCase() === stepName.toLowerCase() ||
      kw.toLowerCase() === (prefix.trim() + ' ' + stepName).toLowerCase()
    );
    if (exactMatch) return; // already matches

    // Find best fuzzy match — same words regardless of BDD prefix
    const stepWords = stepName.toLowerCase().replace(/[^a-z0-9\s]/g, '').split(/\s+/).filter(w => w.length > 2);
    let bestMatch = null;
    let bestScore = 0;

    definedKws.forEach(kw => {
      // Remove any BDD prefix from keyword name for comparison
      const kwClean = kw.replace(/^(Given|When|Then|And|But|Etant donné que?|Quand|Alors|Et|Mais)\s+/i, '').toLowerCase();
      const kwWords = kwClean.replace(/[^a-z0-9\s]/g, '').split(/\s+/).filter(w => w.length > 2);
      const common  = stepWords.filter(w => kwWords.some(kw2 => kw2.includes(w) || w.includes(kw2))).length;
      const score   = common / Math.max(stepWords.length, kwWords.length, 1);
      if (score > bestScore && score > 0.3) { bestScore = score; bestMatch = kw; }
    });

    if (bestMatch) {
      // Replace the step with the correct keyword name
      const oldStep = '    ' + trimmed;
      const newStep = '    ' + prefix + bestMatch.replace(/^(Given|When|Then|And|But|Etant donné que?|Quand|Alors|Et|Mais)\s+/i, '').trim();
      // Only replace if different
      if (oldStep !== newStep) {
        fixed = fixed.replace(oldStep, newStep);
        console.log('  Cross-check: ' + trimmed + ' → ' + newStep.trim());
      }
    }
  });

  if (fixed !== testContent) {
    fs.writeFileSync(testsFile, fixed, 'utf8');
    console.log('  Cross-check: tests.robot updated');
  }

  // ── Fix missing arguments ─────────────────────────────────────────────────
  // Extract keyword signatures (name + arguments) from all resource files
  const kwSignatures = {};
  const extractSignatures = (content) => {
    const lines = content.split('\n');
    let inKw = false, currentKw = null;
    for (const line of lines) {
      if (line.startsWith('*** Keywords')) { inKw = true; continue; }
      if (line.startsWith('***')) { inKw = false; currentKw = null; continue; }
      if (!inKw) continue;
      if (line && !/^\s/.test(line) && line.trim()) {
        currentKw = line.trim();
        kwSignatures[currentKw.toLowerCase()] = { name: currentKw, args: [] };
      } else if (currentKw && line.trim().startsWith('[Arguments]')) {
        const argsStr = line.replace(/\[Arguments\]/, '').trim();
        kwSignatures[currentKw.toLowerCase()].args = argsStr.split(/\s{2,}|\t/).map(a => a.trim()).filter(a => a.startsWith('$') || a.startsWith('@') || a.startsWith('&'));
      }
    }
  };

  extractSignatures(kwContent);
  if (fs.existsSync(pagesDir)) {
    fs.readdirSync(pagesDir).filter(f => f.endsWith('.robot')).forEach(f => {
      try { extractSignatures(fs.readFileSync(path.join(pagesDir, f), 'utf8')); } catch(e) {}
    });
  }

  // Now fix missing arguments in tests.robot
  let fixed2 = fs.readFileSync(testsFile, 'utf8');
  let changed2 = false;
  const lines2 = fixed2.split('\n');
  let inTC = false;
  const fixed2Lines = lines2.map(line => {
    const trimmed = line.trim();
    if (trimmed.startsWith('*** Test Cases')) { inTC = true; return line; }
    if (trimmed.startsWith('***')) { inTC = false; return line; }
    if (!inTC || !trimmed || !/^\s+/.test(line)) return line;

    const prefix = bddPrefixes.find(p => trimmed.startsWith(p));
    const stepName = prefix ? trimmed.slice(prefix.length).trim() : trimmed;
    const stepNameClean = stepName.split(/\s{2,}|\t/)[0].trim(); // keyword name only (no args)

    // Find signature
    const sig = kwSignatures[stepNameClean.toLowerCase()];
    if (!sig || sig.args.length === 0) return line;

    // Count existing args in the call
    const parts = trimmed.split(/\s{2,}|\t/);
    const kwPart = prefix ? parts[0] : parts[0];
    const existingArgs = parts.slice(1).filter(a => a.trim());

    if (existingArgs.length >= sig.args.length) return line; // args already present

    // Inject placeholder args
    const indent = line.match(/^(\s+)/)?.[1] || '    ';
    // Try to extract value from the keyword call name context
    const stepLower = stepNameClean.toLowerCase();
    const numMatch = stepLower.match(/\b(\d+)\b/);
    const placeholders = sig.args.map(a => {
      // Garder le nom de l'argument original — ne pas remplacer par des generiques inexistants
      if (a.startsWith('${') && a.endsWith('}')) return a;
      const name = a.replace(/[${}]/g, '').toLowerCase();
      if (name === 'url') return '${BASE_URL}';
      if (name === 'browser') return '${BROWSER}';
      if (numMatch) return numMatch[1];
      return a;
    });
    const newLine = indent + kwPart + '    ' + placeholders.join('    ');
    console.log('  Cross-check args fix:', trimmed, '→', newLine.trim());
    changed2 = true;
    return newLine;
  });

  if (changed2) {
    fs.writeFileSync(testsFile, fixed2Lines.join('\n'), 'utf8');
    console.log('  Cross-check: tests.robot args updated');
  }
}

// ── Deduplicate *** Variables *** section — keep first occurrence ─────────────
function deduplicateRobotVariables(code) {
  const lines = code.split('\n');
  const seen = new Set();
  const out = [];
  let inVars = false, varsWritten = false;

  for (const line of lines) {
    const t = line.trim();
    if (t.startsWith('*** Variables')) {
      if (varsWritten) { inVars = true; continue; } // skip duplicate header
      varsWritten = true; inVars = true; out.push(line); continue;
    }
    if (t.startsWith('***')) { inVars = false; out.push(line); continue; }
    if (inVars && t) {
      // Extract variable name (e.g. ${BASE_URL} from "${BASE_URL}    value")
      const varName = t.match(/^(\$\{[^}]+\}|\@\{[^}]+\}|\&\{[^}]+\})/)?.[1]?.toLowerCase();
      if (varName) {
        if (seen.has(varName)) continue; // skip duplicate variable
        seen.add(varName);
      }
    }
    out.push(line);
  }
  return out.join('\n');
}

// ── Deduplicate Settings + Keywords sections ─────────────────────────────────
function deduplicateRobotSettings(code) {
  const lines = code.split('\n');
  const seenSettings = new Set();
  const seenKeywords = new Set();
  const out = [];
  let section = '';
  let settingsWritten = false;
  let skipKwBlock = false;

  for (const line of lines) {
    const t = line.trim();
    if (t.startsWith('*** Settings')) {
      if (settingsWritten) { section = 'settings_dup'; continue; }
      settingsWritten = true; section = 'settings'; out.push(line); continue;
    }
    if (t.startsWith('*** Keywords')) {
      section = 'keywords'; skipKwBlock = false; out.push(line); continue;
    }
    if (t.startsWith('***')) {
      section = t.toLowerCase().replace(/\*/g,'').trim();
      skipKwBlock = false; out.push(line); continue;
    }
    if (section === 'settings' && t) {
      const key = t.replace(/\s+/g, ' ').toLowerCase();
      if (seenSettings.has(key)) continue;
      seenSettings.add(key);
      out.push(line); continue;
    }
    if (section === 'settings_dup') {
      if (t) {
        const key = t.replace(/\s+/g, ' ').toLowerCase();
        if (!seenSettings.has(key)) { seenSettings.add(key); out.push(line); }
      }
      continue;
    }
    if (section === 'keywords') {
      if (t && !/^\s/.test(line) && !t.startsWith('#')) {
        const kwName = t.toLowerCase();
        if (seenKeywords.has(kwName)) { skipKwBlock = true; continue; }
        seenKeywords.add(kwName); skipKwBlock = false; out.push(line); continue;
      }
      if (skipKwBlock) continue;
    }
    out.push(line);
  }
  return out.join('\n');
}


// ── Fix AppiumLibrary keyword names ──────────────────────────────────────────
function fixAppiumKeywords(code) {
  if (!code.includes('AppiumLibrary')) return code;
  return code
    .replace(/\bElement Should Contain\b(?!\s+Text)/g,  'Element Should Contain Text')
    .replace(/\bElement Text Should Be\b/g,               'Element Should Contain Text')
    .replace(/\bPage Should Contain\b(?!\s+(Element|Text))/g, 'Page Should Contain Text')
    .replace(/\bClose Browser\b/g,                        'Close Application')
    .replace(/\bOpen Browser\b/g,                         'Open Application');
}

function fixBrowserKeywords(code) {
  const isBrowserLib = code.includes('Library    Browser') && !code.includes('SeleniumLibrary');
  if (!isBrowserLib) return code;

  // Fix XPath-style selectors used as CSS in Browser library
  // button[@class="radius"] → xpath=//button[@class="radius"]
  code = code.replace(/(['"\s])([a-z*]+\[@[^\]]+\])(['"\s])/g, (m, pre, sel, post) => {
    return pre + 'xpath=//' + sel + post;
  });
  // css=button[@class="x"] → xpath=//button[@class="x"]
  code = code.replace(/css=([a-z*]+\[@[^\]]+\])/g, 'xpath=//$1');

  // Fix chrome -> chromium (Browser library only supports chromium/firefox/webkit)
  code = code.replace(/New Browser\s+chrome\b/gi,   'New Browser    chromium')
             .replace(/browser=chrome\b/gi,           'browser=chromium')
             .replace(/\$\{BROWSER\}\s+chrome\b/gi,  '${BROWSER}    chromium');

  return code
    .replace(/\bCapture Page Screenshot\b/g,       'Take Screenshot')
    .replace(/\bShould Be Equal As Strings\s+(\$\{\w+\})\s+(.+)/g, 'Should Contain    $1    $2')
    .replace(/\bOpen Browser\s+(\S+)\s+(\S+)/g,   'New Browser    chromium\nNew Page    $1')
    .replace(/\bInput Text\s+(\S+)/g,              'Fill Text    $1')
    .replace(/\bClick Button\b/g,                  'Click')
    .replace(/\bClick Element\b/g,                 'Click')
    .replace(/\bWait Until Element Is Visible\s+(\S+)(\s+\d+s)?/g, 'Wait For Elements State    $1    visible    timeout=10s')
    .replace(/\bPage Should Contain\b/g,           'Get Text');
}


function detectRunType(code) {
  if (!code) return 'web';
  // AppiumLibrary must be checked first — it may also include Browser keywords
  if (code.includes('AppiumLibrary'))    return 'mobile';
  if (code.includes('RequestsLibrary')) return 'api';
  if (code.includes('DatabaseLibrary')) return 'database';
  // SeleniumLibrary, Browser lib or plain web
  return 'web';
}


