// ── Parse Robot Framework output.xml ─────────────────────────
function parseRobotOutput(xml, stdout, stderr) {
  const results = {
    status:    'UNKNOWN',
    total:     0,
    passed:    0,
    failed:    0,
    skipped:   0,
    duration:  0,
    startTime: '',
    endTime:   '',
    tests:     [],
    stdout,
    stderr,
  };

  // RF7 statistics — <stat pass="3" fail="0" skip="0">All Tests</stat>
  const statMatch = xml.match(/<stat[^>]*pass="(\d+)"[^>]*fail="(\d+)"[^>]*skip="(\d+)"[^>]*>All Tests<\/stat>/);
  if (statMatch) {
    results.passed  = parseInt(statMatch[1]);
    results.failed  = parseInt(statMatch[2]);
    results.skipped = parseInt(statMatch[3]);
    results.total   = results.passed + results.failed + results.skipped;
    results.status  = results.failed > 0 ? 'FAIL' : results.skipped > 0 && results.passed === 0 ? 'SKIP' : 'PASS';
  }

  // Suite duration — last <status> tag inside <suite> (RF7)
  const suiteStatusMatch = xml.match(/<suite[\s\S]*?<status[^>]*elapsed="([\d.]+)"[^>]*\/>/);
  if (suiteStatusMatch) results.duration = Math.round(parseFloat(suiteStatusMatch[1]) * 1000);

  const robotMatch = xml.match(/<robot[^>]*generated="([^"]+)"[^>]*>/);
  if (robotMatch) results.startTime = robotMatch[1];

  // Extract individual test results
  const testRegex = /<test[^>]*name="([^"]+)"[^>]*>([\s\S]*?)<\/test>/g;
  let testMatch;

  while ((testMatch = testRegex.exec(xml)) !== null) {
    const testName    = testMatch[1];
    const testContent = testMatch[2];

    // RF7: test status — handle both self-closing and normal tags
    // Try self-closing first: <status status="PASS" elapsed="0.365"/>
    const allStatusTags = [
      ...testContent.matchAll(/<status\s+status="([^"]+)"[^>]*elapsed="([\d.]+)"[^>]*\/?>/g),
      ...testContent.matchAll(/<status\s+status="([^"]+)"[^\/>\s][^>]*>([^<]*)<\/status>/g),
    ];
    // Also try simple self-closing without elapsed
    const simpleStatus = testContent.match(/<status\s+status="([^"]+)"[^>]*>/);
    const lastStatus   = allStatusTags[allStatusTags.length - 1];
    const rawStatus    = lastStatus ? lastStatus[1] : (simpleStatus ? simpleStatus[1] : 'UNKNOWN');
    const status       = rawStatus === 'SKIPPED' ? 'SKIP' : rawStatus;
    const message      = lastStatus?.[3]?.trim() || '';
    // Fallback message from any ERROR msg
    const errMsg       = testContent.match(/<msg[^>]*level="(?:FAIL|ERROR)"[^>]*>([^<]+)<\/msg>/);
    const finalMessage = message || (errMsg ? errMsg[1].trim() : '');

    // Duration — RF7 uses elapsed="15.171766" (seconds as float)
    let duration = 0;
    const testElapsedMatch = testContent.match(/<status[^>]*elapsed="([\d.]+)"/);
    if (testElapsedMatch) {
      duration = Math.round(parseFloat(testElapsedMatch[1]) * 1000);
    }

    // Tags
    const tags = [];
    const tagRegex = /<tag>([^<]+)<\/tag>/g;
    let tagMatch;
    while ((tagMatch = tagRegex.exec(testContent)) !== null) tags.push(tagMatch[1]);

    // Keywords / steps + screenshot detection
    const steps = [];
    const kwRegex = /<kw[^>]*name="([^"]+)"[^>]*(?:library="([^"]*)")?[^>]*>([\s\S]*?)<\/kw>/g;
    let kwMatch;
    while ((kwMatch = kwRegex.exec(testContent)) !== null) {
      const kwContent = kwMatch[3];
      const kwStat    = kwContent.match(/<status[^>]*status="([^"]+)"[^>]*starttime="([^"]*)"[^>]*endtime="([^"]*)"[^>]*>([^<]*)<\/status>/);
      const kwStatus  = kwStat ? kwStat[1] : 'UNKNOWN';
      const kwMsg     = kwStat ? kwStat[4].trim() : '';
      const kwStart   = kwStat ? kwStat[2] : '';
      const kwEnd     = kwStat ? kwStat[3] : '';

      // Duration per step
      // Step duration — RF7: elapsed="0.125918" in seconds
      let stepDur = 0;
      const stepElapsedM = kwContent.match(/<status[^>]*elapsed="([\d.]+)"/);
      if (stepElapsedM) stepDur = Math.round(parseFloat(stepElapsedM[1]) * 1000);

      // Screenshot — RF7 saves as selenium-screenshot-N.png in cwd/TESTS_DIR
      let screenshot = '';
      // Extract filename from HTML message: href="selenium-screenshot-12.png"
      const hrefMatch = kwContent.match(/href="([^"]+\.png)"/i) || kwMsg.match(/href="([^"]+\.png)"/i);
      const plainMatch = kwMsg.match(/([\w\-\.]+\.png)/i);
      const fname = (hrefMatch && hrefMatch[1]) || (plainMatch && plainMatch[1]);
      if (fname) {
        const searchDirs = [TESTS_DIR, __dirname, process.cwd()];
        for (const dir of searchDirs) {
          const p = path.join(dir, fname);
          if (fs.existsSync(p)) {
            try { screenshot = 'data:image/png;base64,' + fs.readFileSync(p).toString('base64'); break; }
            catch(e) {}
          }
        }
      }

      steps.push({
        name:       kwMatch[1],
        lib:        kwMatch[2] || '',
        status:     kwStatus,
        message:    kwMsg,
        duration:   stepDur,
        screenshot: screenshot,
      });
    }

    // Auto-capture — find latest .png in TESTS_DIR (RF7 saves there since cwd=TESTS_DIR)
    if (status === 'FAIL' && !steps.some(s => s.screenshot)) {
      let allPngs = [];
      for (const dir of [TESTS_DIR, __dirname, process.cwd()]) {
        try {
          const files = fs.readdirSync(dir)
            .filter(f => f.endsWith('.png'))
            .map(f => ({ name: f, dir, time: fs.statSync(path.join(dir, f)).mtimeMs }));
          allPngs = allPngs.concat(files);
        } catch(e) {}
      }
      try {
        const pngFiles = allPngs.sort((a, b) => b.time - a.time);

        if (pngFiles.length > 0) {
          const latestPng = path.join(pngFiles[0].dir, pngFiles[0].name);
          try {
            const imgData = fs.readFileSync(latestPng);
            const b64 = 'data:image/png;base64,' + imgData.toString('base64');
            // Attach to test as failureScreenshot
            if (!steps.some(s => s.screenshot)) {
              steps.push({
                name: 'Screenshot on failure',
                lib: 'SeleniumLibrary',
                status: 'INFO',
                message: pngFiles[0].name,
                duration: 0,
                screenshot: b64,
              });
            }
          } catch(e) {}
        }
      } catch(e) {}
    }

    // Failure analysis
    let failureAnalysis = '';
    let suggestion = '';
    if (status === 'FAIL' && finalMessage) {
      failureAnalysis = analyzeFailure(finalMessage, testName);
      suggestion      = suggestFix(finalMessage);
    }

    results.tests.push({
      name: testName,
      status,
      duration,
      message: finalMessage,
      tags,
      steps,
      failureAnalysis,
      suggestion,
    });

    results.duration += duration;
  }

  return results;
}

// ── Failure analysis ──────────────────────────────────────────
function analyzeFailure(message, testName) {
  const m = message.toLowerCase();
  if (m.includes('element') && (m.includes('not found') || m.includes('did not appear')))
    return '🔍 Sélecteur introuvable — l\'élément HTML n\'existe pas ou n\'est pas encore visible.';
  if (m.includes('timeout') || m.includes('timed out'))
    return '⏱️ Timeout — la page ou l\'élément met trop de temps à répondre.';
  if (m.includes('connection refused') || m.includes('unreachable'))
    return '🌐 Connexion refusée — l\'application cible n\'est pas accessible.';
  if (m.includes('expected') && m.includes('but was'))
    return '❗ Assertion échouée — la valeur obtenue ne correspond pas à celle attendue.';
  if (m.includes('no browser') || m.includes('browser is not open'))
    return '🌐 Navigateur non ouvert — une étape "Open Browser" est manquante.';
  if (m.includes('invalid locator') || m.includes('locator'))
    return '🏷️ Locateur invalide — la syntaxe du sélecteur CSS/XPath est incorrecte.';
  if (m.includes('permission') || m.includes('forbidden'))
    return '🔐 Accès refusé — vérifier les droits ou la connexion.';
  return '⚠️ Échec inattendu — voir le message d\'erreur pour plus de détails.';
}

function suggestFix(message) {
  const m = message.toLowerCase();
  if (m.includes('element') && (m.includes('not found') || m.includes('did not appear')))
    return 'Vérifier le sélecteur dans les DevTools (F12), ajouter un "Wait Until Element Is Visible".';
  if (m.includes('timeout'))
    return 'Augmenter le timeout : Set Selenium Timeout   15s ou utiliser "Wait Until Element Is Visible".';
  if (m.includes('connection refused'))
    return 'Vérifier que l\'application est démarrée et accessible sur l\'URL configurée.';
  if (m.includes('expected') && m.includes('but was'))
    return 'Vérifier la valeur attendue dans le test et la comparer avec la valeur réelle retournée.';
  if (m.includes('no browser'))
    return 'Ajouter "Open Browser  ${URL}  Chrome" avant les interactions.';
  return 'Consulter les logs complets pour identifier la ligne exacte en erreur.';
}


