    });
    return;

  } else {
    // Single file
    const robotDir = path.dirname(robotFile);
    if (!fs.existsSync(robotDir)) fs.mkdirSync(robotDir, { recursive: true });
    // For suite blocs, fix resource paths to point to main rf_tests/resources
