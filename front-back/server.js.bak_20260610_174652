// ── Auto-inject screenshot on failure + keep browser open between runs ────────
function fixSelectors(code) {
  // Fix invalid SeleniumLibrary selector syntax
  // id:xxx → id=xxx
  code = code.replace(/([\s'"])id:([\w-]+)/g, '$1id=$2');
  // css:xxx → css=xxx
  code = code.replace(/([\s'"])css:([^\s'"]+)/g, '$1css=$2');
  // xpath:xxx → xpath=xxx
  code = code.replace(/([\s'"])xpath:([^\s'"]+)/g, '$1xpath=$2');
  // css=button[@class=...] → xpath=//button[@class=...]
  code = code.replace(/css=([a-z*]+\[@[^\]]+\])/g, 'xpath=//$1');
  // button[@class=...] without prefix → xpath=//button[@class=...]
  code = code.replace(/([\s'"])([a-z]+\[@[^\]]+\])([\s'"])/g, (m, pre, sel, post) => pre + 'xpath=//' + sel + post);
  return code;
}

function fixResourcePaths(code, fileRelPath) {
  // Compute absolute base for this file
  const fileDir = path.join(TESTS_DIR, path.dirname(fileRelPath || '')).replace(/\\/g, '/');
  const resourcesAbs = path.join(TESTS_DIR, 'resources').replace(/\\/g, '/');
  const pagesAbs     = path.join(TESTS_DIR, 'resources', 'pages').replace(/\\/g, '/');

  // ../resources/ → absolute (from tests/ subfolder)
  code = code.replace(/Resource\s+\.\.\/resources\//g,  'Resource    ' + resourcesAbs + '/');
  code = code.replace(/Resource\s+\.\.\/resources\//g, 'Resource    ' + resourcesAbs + '/');
  // resources/ -> absolute
  code = code.replace(/Resource\s+resources\//g, 'Resource    ' + resourcesAbs + '/');
  code = code.replace(/Resource\s+resources\//g,       'Resource    ' + resourcesAbs + '/');
  // pages/ → absolute (from resources/ subfolder)
  code = code.replace(/Resource\s+pages\//g,           'Resource    ' + pagesAbs + '/');
  // variables.robot alone → absolute
  code = code.replace(/Resource\s+variables\.robot/g,  'Resource    ' + resourcesAbs + '/variables.robot');
  return code;
}

function injectScreenshotOnFailure(code, browserSession) {
  browserSession = browserSession || 'per-test';
  if (!code.includes('SeleniumLibrary') && !code.includes('Browser')) return code;

  // Register screenshot on failure — ONLY in test files (not resource files)
  const isResourceFile = code.includes('*** Keywords ***') && !code.includes('*** Test Cases ***');
  const isBrowserLib = code.includes('Library    Browser') && !code.includes('SeleniumLibrary');

  if (!isResourceFile) {
    if (isBrowserLib) {
      // Browser library: no screenshot teardown injection — page may be closed
      // Screenshots are taken by Browser library's built-in failure handling
    } else if (!code.includes('Register Keyword To Run On Failure') && !code.includes('Suite Setup')) {
      // SeleniumLibrary / AppiumLibrary
      code = code.replace(
        /(\*\*\* Settings \*\*\*[^\n]*\n)/,
        '$1Suite Setup    Register Keyword To Run On Failure    Capture Page Screenshot\n'
      );
    }
  }
  // Replace any remaining Capture Page Screenshot with Take Screenshot for Browser lib
  if (isBrowserLib) {
    code = code.replace(/Capture Page Screenshot/g, 'Take Screenshot');
    // Also fix in [Teardown] lines
    code = code.replace(/\[Teardown\]\s+Capture Page Screenshot/g, '[Teardown]    Take Screenshot');
  }

  // ── Clean malformed test cases — remove Settings lines leaked into *** Test Cases ***
  if (code.includes('*** Test Cases ***')) {
    // First: remove duplicate *** Settings *** sections — keep only the first
    const settingsSections = [...code.matchAll(/^\*{3}\s*Settings\s*\*{3}[^\n]*$/gm)];
    if (settingsSections.length > 1) {
      // Remove all Settings sections after the first
      let firstFound = false;
      code = code.split('\n').reduce((acc, line) => {
        if (/^\*{3}\s*Settings\s*\*{3}/.test(line)) {
          if (!firstFound) { firstFound = true; acc.push(line); }
          // Skip subsequent Settings headers and their content until next ***
          return acc;
        }
        acc.push(line);
        return acc;
      }, []).join('\n');
    }

    // Second: fix missing *** Settings *** header and clean leaked directives
    const lines2 = code.split('\n');
    const firstLine = lines2[0]?.trim();
    // If file starts with a directive without *** Settings ***, add it
    const startsWithDirective = /^(Documentation|Library|Resource|Suite Setup|Suite Teardown|Test Setup|Test Teardown)[ \t]+/.test(firstLine);
    const hasSettingsHeader = code.includes('*** Settings');
    if (startsWithDirective && !hasSettingsHeader) {
      code = '*** Settings ***\n' + code;
    }

    // Now clean leaked directives inside *** Test Cases ***
    const lines3 = code.split('\n');
    let inTests3 = false;
    const cleaned3 = [];
    for (const line of lines3) {
      const t = line.trim();
      if (!t) { cleaned3.push(line); continue; }
      if (/^\*{3}\s*Test Cases/.test(t)) { inTests3 = true; cleaned3.push(line); continue; }
      if (/^\*{3}/.test(t))               { inTests3 = false; cleaned3.push(line); continue; }
      if (inTests3) {
        const isLeaked = /^(Documentation|Library|Resource|Suite Setup|Suite Teardown|Test Setup|Test Teardown|Metadata|Force Tags|Default Tags|Variables)[ \t]+/.test(t)
          && !/^[ \t]/.test(line);
        if (isLeaked) continue;
      }
      cleaned3.push(line);
    }
    code = cleaned3.join('\n');
  }

  // ── Browser session mode ─────────────────────────────────────────────────────
  const bSession = browserSession || 'per-test';
  const hasTestCases = code.includes('*** Test Cases ***');

  if (bSession === 'per-suite' && hasTestCases) {
    // Find Open Browser in tests.robot OR in keywords/pages files on disk
    let openBrowserMatches = [...code.matchAll(/Open Browser\s+(\S+)\s+(\S+)/g)];

    // If not in tests.robot, search in resources on disk
    if (openBrowserMatches.length === 0) {
      const searchDirs = [
        path.join(TESTS_DIR, 'resources'),
        path.join(TESTS_DIR, 'tests'),
      ];
      for (const dir of searchDirs) {
        if (!fs.existsSync(dir)) continue;
        const files = fs.readdirSync(dir);
        for (const f of files) {
          if (!f.endsWith('.robot')) continue;
          try {
            const content = fs.readFileSync(path.join(dir, f), 'utf8');
            const matches = [...content.matchAll(/Open Browser\s+(\S+)\s+(\S+)/g)];
            if (matches.length > 0) { openBrowserMatches = matches; break; }
          } catch(e) {}
        }
        if (openBrowserMatches.length > 0) break;
      }
    }

    // Fallback URL from variables.robot
    let firstUrl     = '\${BASE_URL}';
    let firstBrowser = '\${BROWSER}';
    if (openBrowserMatches.length > 0) {
      firstUrl     = openBrowserMatches[0][1] || '\${BASE_URL}';
      firstBrowser = openBrowserMatches[0][2] || '\${BROWSER}';
    } else {
      // Read BASE_URL from variables.robot
      try {
        const varFile = path.join(TESTS_DIR, 'resources', 'variables.robot');
        if (fs.existsSync(varFile)) {
          const varContent = fs.readFileSync(varFile, 'utf8');
          const urlMatch = varContent.match(/\$\{BASE_URL\}\s+(\S+)/);
          if (urlMatch) firstUrl = urlMatch[1];
        }
      } catch(e) {}
    }
    const allSameApp = true;

      if (allSameApp) {
        // ── Suite Teardown : Open once → run all tests → Close once ──────────
        function fixSuiteMode(c) {
          // Replace Open Browser with Go To (but NOT in Suite Setup lines)
          c = c.replace(/^([ \t]+)Open Browser\s+(\S+)(.*)?$/gm, (m, indent, url) => indent + 'Go To    ' + url);
          // Protect Suite Setup — convert back if accidentally converted
          c = c.replace(/^(Suite Setup[ \t]+)Go To([ \t]+\S+)([ \t]*)$/gm,
            (m, prefix, url) => prefix + 'Open Browser' + url + '    \${BROWSER}');

          // Remove ALL direct close keywords
          c = c.replace(/^[ \t]+(Close Browser|Close Application|Close Mobile Browser|Close Browser Session)[^\n]*$/gm, '');

          // Remove [Teardown] lines
          c = c.replace(/^[ \t]+\[Teardown\][^\n]*$/gm, '');

          // Remove ANY BDD step that contains "close" + (browser/application/session)
          c = c.replace(/^[ \t]+(Given|When|Then|And|But|Finally)[ \t]+[^\n]*(Close|close)[^\n]*(Browser|Application|Session|browser|application|session)[^\n]*$/gm, '');

          // Remove ANY BDD step that opens browser in per-suite mode
          // e.g. "Given User Opens Login Application", "Given Open Login Page"
          c = c.replace(/^[ \t]+(Given|When|Then|And|But)[ \t]+[^\n]*(Open|open)[^\n]*(Login|Page|App|Application|Browser|browser)[^\n]*$/gm, '');

          // Remove direct Open Browser calls (not already handled)
          c = c.replace(/^[ \t]+Open Application[^\n]*$/gm, '');

          return c;
        }

        code = fixSuiteMode(code);

        // Remove Test Teardown / Suite Setup injected previously
        code = code.replace(/^Test Teardown[^\n]+\n?/gm, '');
        code = code.replace(/^Suite Setup\s+Register Keyword To Run On Failure[^\n]+\n?/gm, '');

        // Also fix resource files on disk (keywords.robot, pages/*.robot)
        const resourcesPath = path.join(TESTS_DIR, 'resources');
        if (fs.existsSync(resourcesPath)) {
          const fixDir = (dir) => {
            fs.readdirSync(dir).forEach(f => {
              const fp = path.join(dir, f);
              if (fs.statSync(fp).isDirectory()) { fixDir(fp); return; }
              if (!f.endsWith('.robot')) return;
              try {
                const content = fs.readFileSync(fp, 'utf8');
                const fixed   = fixSuiteMode(content);
                if (fixed !== content) {
                  fs.writeFileSync(fp, fixed, 'utf8');
                  console.log('  Suite mode: fixed', f);
                }
              } catch(e) {}
            });
          };
          fixDir(resourcesPath);
        }

        // Remove existing Suite Setup / Suite Teardown
        code = code.replace(/^Suite Setup[^\n]+\n?/gm, '');
        code = code.replace(/^Suite Teardown[^\n]+\n?/gm, '');

        // Add Suite Setup (Open Browser ONCE) AFTER fixSuiteMode so it's not converted to Go To
        const popupOptsLine = '    options=' + popupArgs;
        const optsSuffix = '    options=' + popupArgs;
        // Use firstUrl/firstBrowser already detected from Open Browser calls
        // They come from keywords.robot and pages/*.robot files
        let urlVar = firstUrl || '\${BASE_URL}';
        let browserVar = firstBrowser || '\${BROWSER}';
        // If firstUrl is a hardcoded URL (not a variable), convert to variable
        if (!urlVar.startsWith('\${')) {
          urlVar = '\${BASE_URL}';
        }

        code = code.replace(
          /(\*\*\* Settings \*\*\*[^\n]*\n)/,
          '$1Suite Setup       Open Browser    ' + urlVar + '    ' + browserVar + optsSuffix + '\n' +
          (code.includes('AppiumLibrary') ? 'Suite Teardown    Close Application\n' : 'Suite Teardown    Close Browser\n') +
          'Test Setup        Go To    ' + urlVar + '\n'
        );
    }

  } else if (bSession === 'per-test' && hasTestCases) {
    // ── Test Teardown : each test opens and closes its own browser ────────────
    const isAppium = code.includes('AppiumLibrary');
    const closeCmd = isAppium ? 'Close Application' : 'Close Browser';

    // For Appium: if each test already calls Close Mobile Browser / Close Application
    // don't inject Test Teardown to avoid double close
    const alreadyCloses = isAppium
      ? (code.includes('Close Mobile Browser') || code.includes('Close Application'))
      : (code.includes('Close Browser'));

    if (!alreadyCloses) {
      code = code.replace(
        /(\*\*\* Settings \*\*\*[^\n]*\n)/,
        '$1Test Teardown    Run Keywords    Capture Page Screenshot    AND    ' + closeCmd + '\n'
      );
    } else {
      // Just add screenshot on failure without close
      code = code.replace(
        /(\*\*\* Settings \*\*\*[^\n]*\n)/,
        '$1Test Teardown    Capture Page Screenshot\n'
      );
    }
    // Remove individual [Teardown] lines to avoid duplicates
    code = code.replace(/^([ \t]+)\[Teardown\][^\n]+$/gm, '');
    // Injecter Test Setup Open Browser No Popup si pas deja present
    if (!code.includes('Test Setup') && !code.includes('Suite Setup')) {
      const urlVar = code.includes('${BASE_URL}') ? '${BASE_URL}' : code.includes('${URL}') ? '${URL}' : '${BASE_URL}';
      code = code.replace(
        /(\*\*\* Settings \*\*\*[^\n]*\n)/,
        '$1Test Setup    Open Browser No Popup    ' + urlVar + '    ${BROWSER}\n'
      );
    }
  }

  // Detect base URL in this test
  const urlMatch = code.match(/Open Browser\s+(\S+)\s+/);
  const currentUrl = urlMatch ? urlMatch[1] : null;
  const baseUrl = currentUrl ? (() => {
    try { const u = new URL(currentUrl.replace(/\${[^}]+}/g,'http://placeholder')); return u.hostname; } catch(e) { return currentUrl; }
  })() : null;

  // If same app (same hostname) — don't close browser between tests, reuse it
  const sameApp = _lastTestedUrl && baseUrl && _lastTestedUrl === baseUrl;

  if (sameApp) {
    // Replace "Close Browser" teardown with just a screenshot — keep browser open
    code = code.replace(
      /\[Teardown\]\s+Close Browser\s*$/gm,
      '[Teardown]    Capture Page Screenshot'
    );
    code = code.replace(
      /\[Teardown\]\s+Run Keywords\s+Capture Page Screenshot\s+AND\s+Close Browser/g,
      '[Teardown]    Capture Page Screenshot'
    );
    // Replace Open Browser with Switch Browser or Go To if browser already open
    code = code.replace(
      /(Open Browser\s+)(\S+)(\s+)(chrome|Chrome)/g,
      'Go To    $2'
    );
  } else {
    // Different app or first run — close browser normally after tests
    code = code.replace(
      /\[Teardown\]\s+Close Browser/g,
      '[Teardown]    Run Keywords    Capture Page Screenshot    AND    Close Browser'
    );
  }

  if (baseUrl) _lastTestedUrl = baseUrl;

  return code;
}


